# Copy this file to .env.local and fill in your values.
# cp .env.example .env.local

# ── Database ──────────────────────────────────────────────────────────────────
# Use "postgres" when running inside Docker Compose, "localhost" otherwise.
DB_HOST=postgres
DB_PORT=5432
DB_NAME=fastifyadmin
DB_USER=postgres
DB_PASSWORD=password

# ── Auth ──────────────────────────────────────────────────────────────────────
# Change this to a long random string before going to production!
JWT_SECRET=change-me-in-production

# ── Admin panel ───────────────────────────────────────────────────────────────
ADMIN_NAME=FastifyAdmin
SIGNUP_ENABLED=true
PORT=3001
APP_BASE_URL=http://localhost:3001

# ── Email / SMTP ──────────────────────────────────────────────────────────────
# Required for MFA codes and signup email verification.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=you@gmail.com

# ── OAuth — Google ────────────────────────────────────────────────────────────
# Leave empty to hide the "Continue with Google" button.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── OAuth — GitHub ────────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── OAuth — Microsoft ─────────────────────────────────────────────────────────
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ── Docker dev ────────────────────────────────────────────────────────────────
CHOKIDAR_USEPOLLING=true
